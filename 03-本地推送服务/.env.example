# ============================================================
# 环境变量配置文件（敏感信息）
# 复制此文件为 .env，填入真实值
# 注意：.env 文件不要提交到代码仓库，已在 .gitignore 中排除
# ============================================================

# ── 企业微信应用接口 ──────────────────────────────────────────
# corpid：企业ID（在企微管理后台 → 我的企业 → 企业信息 中查看）
WECOM_CORPID=your_corpid_here

# agentid：应用AgentID（在企微管理后台 → 应用管理 → 应用详情 中查看）
WECOM_AGENTID=your_agentid_here

# secret：应用Secret（在企微管理后台 → 应用管理 → 应用详情 中查看）
WECOM_SECRET=your_secret_here

# ── GitHub 图床 ───────────────────────────────────────────────
# GitHub Token：GitHub Settings → Developer settings → Personal access tokens → Fine-grained tokens
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_username_here
GITHUB_REPO=ai-daily-images
GITHUB_BRANCH=main

# ── QQ邮箱 SMTP ───────────────────────────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code_here
SENDER_NAME=GESC AI知识学习与应用服务组

# ── 企业微信 Webhook ─────────────────────────────────────
WECOM_WEBHOOK_KEY=your_webhook_key_here

# ── 推送结果反馈收件人 ─────────────────────────────────────────
FEEDBACK_WECOM_USER=your_wecom_userid_here
FEEDBACK_EMAIL=your_email@example.com
